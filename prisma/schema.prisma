// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// --- 下面是你的业务数据模型 ---
model Level {
  id          String     @id // 例如 "n1"
  title       String // 例如 "N1 听力"
  description String? // 例如 "包含 N1 历年真题及模拟题"
  categories  Category[] // 关联下面具体的试卷
}

// 🌟 2. 修改：具体试卷表 (如 25年7月真题)
model Category {
  id          String    @id // 例如 "N1_202507"
  levelId     String // 记录它属于哪个大模块
  level       Level     @relation(fields: [levelId], references: [id])
  name        String // 例如 "2025年7月 N1真题"
  description String? // 👈 试卷自己的单独描述！
  lessons     Lesson[]
  articles    Article[]
  quizzes     Quiz[]
  sortOrder   Int       @default(0)
}

// 3. 课程和字幕表保持不变
model Lesson {
  id         String     @id @default(uuid())
  title      String
  audioFile  String
  categoryId String
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  dialogues  Dialogue[]
  sortOrder  Int        @default(0)
  createdAt  DateTime   @default(now())
}

model Dialogue {
  id         Int    @id @default(autoincrement())
  sequenceId Int
  text       String
  start      Float
  end        Float
  lessonId   String
  lesson     Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// 🌟 核心枚举：定义语料的来源类型
enum SourceType {
  AUDIO_DIALOGUE // 来自听力跟读
  ARTICLE_TEXT // 来自阅读文章
  QUIZ_QUESTION // 来自选择题
}

// 题目类型枚举
enum QuestionType {
  PRONUNCIATION // 读音题 (例如：汉字选假名)
  WORD_DISTINCTION // 单词辨析题（一个词 + 四个语境句）
  FILL_BLANK // 填空题 (例如：选词填空)
  GRAMMAR // 语法题
  TRANSLATION // 翻译题
  SORTING
  READING_COMPREHENSION
}

model Vocabulary {
  id   String @id @default(cuid())
  word String // 选中的生词，例如 "コミュニケーション"

  // 🌟 核心来源字段：记录该词最初收录时的来源
  sourceType     SourceType
  sourceId       String
  groupName      String?
  wordAudio      String?
  pronunciations String?
  partsOfSpeech  String?
  meanings       String?
  folderId       String?
  folder         VocabularyFolder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  review         VocabularyReview?
  createdAt      DateTime   @default(now())
  sentenceLinks  VocabularySentenceLink[]
}

model VocabularyReview {
  id String @id @default(cuid())

  vocabularyId String     @unique
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  // FSRS core fields (same shape as SentenceReview)
  due            DateTime @default(now())
  state          Int      @default(0)
  stability      Float    @default(0)
  difficulty     Float    @default(0)
  elapsed_days   Int      @default(0)
  scheduled_days Int      @default(0)
  reps           Int      @default(0)
  lapses         Int      @default(0)
  learning_steps Int      @default(0)
  last_review    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([due])
}

model VocabularyFolder {
  id          String       @id @default(cuid())
  name        String       @unique
  createdAt   DateTime     @default(now())
  vocabularies Vocabulary[]
}

model VocabularySentence {
  id             String                  @id @default(cuid())
  text           String
  normalizedText String
  translation    String?
  audioFile      String?
  source         String
  sourceUrl      String
  sourceType     SourceType?
  sourceId       String?
  createdAt      DateTime                @default(now())
  links          VocabularySentenceLink[]

  @@unique([normalizedText, sourceUrl])
}

model VocabularySentenceLink {
  id           String             @id @default(cuid())
  vocabularyId String
  sentenceId   String
  meaningIndex Int?
  posTags      String?
  createdAt    DateTime           @default(now())
  vocabulary   Vocabulary         @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  sentence     VocabularySentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)

  @@unique([vocabularyId, sentenceId])
}

model SentenceReview {
  id String @id @default(cuid())

  text           String
  sourceType     SourceType
  sourceId       String
  // FSRS 核心算法字段 (必须完全对齐 ts-fsrs 的 Card 类型)
  due            DateTime   @default(now())
  state          Int        @default(0)
  stability      Float      @default(0)
  difficulty     Float      @default(0)
  elapsed_days   Int        @default(0)
  scheduled_days Int        @default(0)
  reps           Int        @default(0)
  lapses         Int        @default(0)
  learning_steps Int        @default(0) // 记录当前处于短时记忆的第几步
  last_review    DateTime? // 记录上一次复习的精确时间
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// 📖 文章主表
model Article {
  id          String  @id @default(cuid())
  title       String
  description String? // 文章简介或背景

  // 🌟 核心优化：直接用一个长文本字段存整篇文章！
  content String // 如果你用的是 MySQL/PostgreSQL，建议加上 @db.Text 防止超长截断

  categoryId String
  category   Category? @relation(fields: [categoryId], references: [id])

  questions Question[]
  createdAt DateTime   @default(now())
  sortOrder Int        @default(0)
}

// 📝 题库集 (例如："N1真题 2023年7月 词汇部分")
model Quiz {
  id          String  @id @default(cuid())
  title       String
  description String?

  categoryId String
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime   @default(now())
  questions Question[]
  sortOrder Int        @default(0)
}

// 📝 独立题目表
model Question {
  id     String  @id @default(cuid())
  quizId String?
  quiz   Quiz?   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  questionType QuestionType // 题型：读音、填空等

  // 💡 核心设计：题目的完整语境句子 (用户可以直接收藏这整句话)
  contextSentence String

  // 特殊字段：如果是读音题，这里存那个被画线的词 (例如 "合宿")
  targetWord String?

  // 题干提示 (例如："划线部分的读音是？"，可以为空)
  prompt String?

  options QuestionOption[] // 选项

  // 💡 绝佳体验：题目解析 (用户做完题后展示，里面也可以点词成金！)
  explanation String?

  order    Int // 题目序号
  createdAt DateTime @default(now())
  attempts QuestionAttempt[]
  retryQueue QuestionRetry?

  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String?
}

// 📝 题目选项表
model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  text      String // 选项文本
  isCorrect Boolean @default(false) // 是否为正确答案
}

model QuestionAttempt {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  isCorrect   Boolean // 用户是否做对
  timeSpentMs Int // 这道题思考/停留的耗时（毫秒）

  createdAt DateTime @default(now())

  // 💡 未来如果你加了用户登录系统，可以把下面两行取消注释，绑定到具体用户
  // userId      String?
  // user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuestionRetry {
  id         String   @id @default(cuid())
  questionId String   @unique
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  stage      Int      @default(0) // 0 -> 24h, 1 -> 72h, 2 -> 7d
  dueAt      DateTime
  wrongCount Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([dueAt])
}

model GameProfile {
  id             String          @id @default("default")
  xp             Int             @default(0)
  level          Int             @default(1)
  difficultyPreset GameDifficultyPreset @default(STANDARD)
  coins          Int             @default(0)
  streakDays     Int             @default(0)
  lastStreakDate String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessions       GameSessionLog[]
  fsrsProfile    FSRSProfile?
  reviewEvents   ReviewEvent[]
  outputPractices OutputPractice[]
}

enum GameDifficultyPreset {
  CONSERVATIVE
  STANDARD
  AGGRESSIVE
}

model FSRSProfile {
  id               String      @id @default(cuid())
  profileId        String      @unique
  profile          GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  requestRetention Float       @default(0.9)
  maximumInterval  Int         @default(36500)
  weights          String
  sampleSize       Int         @default(0)
  fitVersion       Int         @default(1)
  enabled          Boolean     @default(true)
  lastEngineMode   String      @default("custom")
  lastFallbackReason String?
  lastFallbackAt   DateTime?
  lastFittedAt     DateTime?
  lastEventAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model ReviewEvent {
  id              String      @id @default(cuid())
  profileId       String
  profile         GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reviewId        String
  sourceType      SourceType
  sourceId        String
  rating          Int
  deltaDays       Int
  scheduledDays   Int
  stateBefore     Int
  stateAfter      Int
  stabilityBefore Float
  stabilityAfter  Float
  difficultyBefore Float
  difficultyAfter  Float
  dueAt           DateTime
  reviewedAt      DateTime    @default(now())
  wasOverdue      Boolean
  wasRecallSuccess Boolean

  @@index([profileId, reviewedAt])
  @@index([reviewId, reviewedAt])
}

model GameSessionLog {
  id           String      @id @default(cuid())
  profileId    String
  profile      GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  dateKey      String
  taskKey      String
  taskTitle    String
  points       Int
  coins        Int         @default(0)
  durationMin  Int         @default(0)
  completedAt  DateTime    @default(now())

  @@unique([profileId, dateKey, taskKey])
  @@index([dateKey])
}

enum StudyTimeKind {
  LESSON_SPEAKING
  ARTICLE_READING
}

model StudyTimeDaily {
  id        String        @id @default(cuid())
  dateKey   String
  kind      StudyTimeKind
  seconds   Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([dateKey, kind])
  @@index([dateKey])
}

model LearningDiary {
  id        String   @id @default(cuid())
  dateKey   String   @unique
  content   String
  wordCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MorningRecall {
  id            String   @id @default(cuid())
  dateKey       String   @unique
  sourceDateKey String
  prompt        String
  content       String
  wordCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum OutputPracticeType {
  WRITING
}

model OutputPractice {
  id                String             @id @default(cuid())
  profileId         String
  profile           GameProfile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  dateKey           String
  practiceType      OutputPracticeType @default(WRITING)
  languageCode      String             @default("ja")
  missionPrompt     String
  missionText       String
  learnerText       String
  aiCoachPrompt     String
  aiFeedbackRaw     String
  totalScore        Int                @default(0)
  comprehensibility Int                @default(0)
  accuracy          Int                @default(0)
  complexity        Int                @default(0)
  taskCompletion    Int                @default(0)
  feedbackSummary   String?
  actionItems       String?
  wordCount         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([profileId, dateKey, practiceType])
  @@index([dateKey])
}
