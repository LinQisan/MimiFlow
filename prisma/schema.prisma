// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// --- 下面是你的业务数据模型 ---
model Level {
  id          String     @id // 例如 "n1"
  title       String // 例如 "N1 听力"
  description String? // 例如 "包含 N1 历年真题及模拟题"
  categories  Category[] // 关联下面具体的试卷
}

// 🌟 2. 修改：具体试卷表 (如 25年7月真题)
model Category {
  id          String   @id // 例如 "N1_202507"
  levelId     String // 记录它属于哪个大模块
  level       Level    @relation(fields: [levelId], references: [id])
  name        String // 例如 "2025年7月 N1真题"
  description String? // 👈 试卷自己的单独描述！
  lessons     Lesson[]
}

// 3. 课程和字幕表保持不变
model Lesson {
  id         String     @id @default(uuid())
  lessonNum  String
  title      String
  audioFile  String
  categoryId String
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  dialogues  Dialogue[]
}

model Dialogue {
  id             Int             @id @default(autoincrement())
  sequenceId     Int
  text           String
  start          Float
  end            Float
  lessonId       String
  lesson         Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  vocabularies   Vocabulary[]
  sentenceReview SentenceReview?
}

model Vocabulary {
  id   String @id @default(cuid())
  word String // 选中的生词，例如 "コミュニケーション"

  // 🌟 核心：直接关联到具体的句子
  dialogueId Int
  dialogue   Dialogue @relation(fields: [dialogueId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model SentenceReview {
  id         String   @id @default(cuid())
  dialogueId Int      @unique
  dialogue   Dialogue @relation(fields: [dialogueId], references: [id], onDelete: Cascade)

  // FSRS 核心算法字段 (必须完全对齐 ts-fsrs 的 Card 类型)
  due            DateTime  @default(now())
  state          Int       @default(0)
  stability      Float     @default(0)
  difficulty     Float     @default(0)
  elapsed_days   Int       @default(0)
  scheduled_days Int       @default(0)
  reps           Int       @default(0)
  lapses         Int       @default(0)
  learning_steps Int       @default(0) // 记录当前处于短时记忆的第几步
  last_review    DateTime? // 记录上一次复习的精确时间
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
