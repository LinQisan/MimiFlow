// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SourceType {
  AUDIO_DIALOGUE // 来自听力跟读
  ARTICLE_TEXT // 来自阅读文章
  QUIZ_QUESTION // 来自选择题
}

enum MaterialType {
  LISTENING
  READING
  VOCAB_GRAMMAR
  SPEAKING
}

enum QuestionTemplate {
  CHOICE_QUIZ // 单/多选题
  CLOZE_TEST // 完形填空
  FILL_BLANK // 填空题
}

enum CollectionType {
  LIBRARY_ROOT // 系统内容根分类（例如：口语/阅读/听力）
  BOOK // 一本书/一套教材/一个官方内容合集
  CHAPTER // 章节/Unit/Lesson
  PAPER // 官方试卷
  CUSTOM_GROUP // 用户自定义分组/生词本
  FAVORITES // 默认收藏夹
}

// 题目类型枚举
enum QuestionType {
  PRONUNCIATION // 读音题 (例如：汉字选假名)
  WORD_DISTINCTION // 单词辨析题（一个词 + 四个语境句）
  FILL_BLANK // 填空题 (例如：选词填空)
  GRAMMAR // 语法题
  TRANSLATION // 翻译题
  SORTING
  READING_COMPREHENSION
  SYNONYM_REPLACEMENT // 近义词替换题
  LISTENING // 听力理解题
}

model Material {
  id             String       @id @default(uuid())
  type           MaterialType
  title          String
  chapterName    String?      @map("chapter_name")
  contentPayload Json         @map("content_payload")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  questions           Question[]
  collectionMaterials CollectionMaterial[]
  studyProgresses     MaterialStudyProgress[]
  playtimeStats       MaterialPlaytimeStat[]

  @@map("materials")
}

model Vocabulary {
  id   String @id @default(cuid())
  word String

  sourceType     SourceType
  sourceId       String
  groupName      String?
  wordAudio      String?
  pronunciations String?
  partsOfSpeech  String?
  meanings       String?
  folderId       String?
  folder         VocabularyFolder?           @relation(fields: [folderId], references: [id], onDelete: SetNull)
  review         VocabularyReview?
  createdAt      DateTime                    @default(now())
  sentenceLinks  VocabularySentenceLink[]
  tags           VocabularyTagOnVocabulary[]
}

model VocabularyTag {
  id           String                      @id @default(cuid())
  name         String                      @unique
  createdAt    DateTime                    @default(now())
  vocabularies VocabularyTagOnVocabulary[]
}

model VocabularyTagOnVocabulary {
  vocabularyId String
  tagId        String
  createdAt    DateTime      @default(now())
  vocabulary   Vocabulary    @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  tag          VocabularyTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([vocabularyId, tagId])
  @@index([tagId])
}

model VocabularyReview {
  id String @id @default(cuid())

  vocabularyId String     @unique
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  // FSRS core fields (same shape as SentenceReview)
  due            DateTime  @default(now())
  state          Int       @default(0)
  stability      Float     @default(0)
  difficulty     Float     @default(0)
  elapsed_days   Int       @default(0)
  scheduled_days Int       @default(0)
  reps           Int       @default(0)
  lapses         Int       @default(0)
  learning_steps Int       @default(0)
  last_review    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([due])
}

model VocabularyFolder {
  id           String             @id @default(cuid())
  name         String
  parentId     String?
  parent       VocabularyFolder?  @relation("VocabularyFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     VocabularyFolder[] @relation("VocabularyFolderTree")
  createdAt    DateTime           @default(now())
  vocabularies Vocabulary[]

  @@unique([parentId, name])
  @@index([parentId])
}

model VocabularySentence {
  id             String                   @id @default(cuid())
  text           String
  normalizedText String
  translation    String?
  audioFile      String?
  source         String
  sourceUrl      String
  sourceType     SourceType?
  sourceId       String?
  createdAt      DateTime                 @default(now())
  links          VocabularySentenceLink[]
  grammarExamples GrammarExample[]

  @@unique([normalizedText, sourceUrl])
}

enum GrammarExampleSource {
  MANUAL
  SENTENCE_DB
}

model Grammar {
  id          String                @id @default(cuid())
  name        String
  meaning     String?               @db.Text
  usageNote   String?               @map("usage_note") @db.Text
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  tags        GrammarTagOnGrammar[]
  examples    GrammarExample[]
  clusters    GrammarClusterMember[]
  constructions GrammarConstruction[]

  @@index([name])
  @@map("grammars")
}

model GrammarConstruction {
  id          String    @id @default(cuid())
  grammarId   String    @map("grammar_id")
  connection  String    @db.Text
  meaning     String    @db.Text
  note        String?   @db.Text
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  grammar     Grammar   @relation(fields: [grammarId], references: [id], onDelete: Cascade)
  examples    GrammarExample[]

  @@index([grammarId, sortOrder])
  @@map("grammar_constructions")
}

model GrammarTag {
  id         String               @id @default(cuid())
  name       String               @unique
  createdAt  DateTime             @default(now()) @map("created_at")
  grammars   GrammarTagOnGrammar[]

  @@map("grammar_tags")
}

model GrammarTagOnGrammar {
  grammarId  String
  tagId      String
  createdAt  DateTime   @default(now()) @map("created_at")
  grammar    Grammar    @relation(fields: [grammarId], references: [id], onDelete: Cascade)
  tag        GrammarTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([grammarId, tagId])
  @@index([tagId])
  @@map("grammar_tag_on_grammar")
}

model GrammarCluster {
  id          String                 @id @default(cuid())
  title       String                 @unique
  description String?                @db.Text
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  members     GrammarClusterMember[]

  @@map("grammar_clusters")
}

model GrammarClusterMember {
  clusterId   String
  grammarId   String
  createdAt   DateTime       @default(now()) @map("created_at")
  cluster     GrammarCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  grammar     Grammar        @relation(fields: [grammarId], references: [id], onDelete: Cascade)

  @@id([clusterId, grammarId])
  @@index([grammarId])
  @@map("grammar_cluster_members")
}

model GrammarExample {
  id              String               @id @default(cuid())
  grammarId       String               @map("grammar_id")
  source          GrammarExampleSource
  sentenceText    String               @map("sentence_text") @db.Text
  translation     String?              @db.Text
  note            String?              @db.Text
  sentenceId      String?              @map("sentence_id")
  constructionId  String?              @map("construction_id")
  createdAt       DateTime             @default(now()) @map("created_at")
  grammar         Grammar              @relation(fields: [grammarId], references: [id], onDelete: Cascade)
  sentence        VocabularySentence?  @relation(fields: [sentenceId], references: [id], onDelete: SetNull)
  construction    GrammarConstruction? @relation(fields: [constructionId], references: [id], onDelete: SetNull)

  @@index([grammarId, createdAt])
  @@index([sentenceId])
  @@index([constructionId])
  @@map("grammar_examples")
}

model VocabularySentenceLink {
  id           String             @id @default(cuid())
  vocabularyId String
  sentenceId   String
  meaningIndex Int?
  posTags      String?
  createdAt    DateTime           @default(now())
  vocabulary   Vocabulary         @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  sentence     VocabularySentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)

  @@unique([vocabularyId, sentenceId])
}

model SentenceReview {
  id String @id @default(cuid())

  text           String
  sourceType     SourceType
  sourceId       String
  // FSRS 核心算法字段 (必须完全对齐 ts-fsrs 的 Card 类型)
  due            DateTime   @default(now())
  state          Int        @default(0)
  stability      Float      @default(0)
  difficulty     Float      @default(0)
  elapsed_days   Int        @default(0)
  scheduled_days Int        @default(0)
  reps           Int        @default(0)
  lapses         Int        @default(0)
  learning_steps Int        @default(0) // 记录当前处于短时记忆的第几步
  last_review    DateTime? // 记录上一次复习的精确时间
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Question {
  id           String           @id @default(uuid())
  materialId   String           @map("material_id")
  templateType QuestionTemplate @map("template_type")
  content      Json
  prompt       String?          @db.Text
  context      String?          @db.Text
  options      Json?
  answer       Json
  analysis     String?          @db.Text
  note         String?          @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  sortOrder    Int              @default(0) @map("sort_order")

  material   Material          @relation(fields: [materialId], references: [id], onDelete: Cascade)
  attempts   QuestionAttempt[]
  retryQueue QuestionRetry?

  @@map("questions")
}

model Collection {
  id             String         @id @default(uuid())
  title          String
  description    String?        @db.Text
  language       String?
  level          String?
  collectionType CollectionType @map("collection_type")
  parentId       String?        @map("parent_id")
  sortOrder      Int            @default(0) @map("sort_order")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  parent    Collection?         @relation("CollectionTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Collection[]        @relation("CollectionTree")
  materials CollectionMaterial[]

  @@index([parentId, sortOrder])
  @@map("collections")
}

model CollectionMaterial {
  id           String   @id @default(uuid())
  collectionId String   @map("collection_id")
  materialId   String   @map("material_id")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  material   Material   @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([collectionId, materialId])
  @@map("collection_materials")
}

model QuestionAttempt {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  isCorrect   Boolean // 用户是否做对
  timeSpentMs Int // 这道题思考/停留的耗时（毫秒）

  createdAt DateTime @default(now())

  // 💡 未来如果你加了用户登录系统，可以把下面两行取消注释，绑定到具体用户
  // userId      String?
  // user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuestionRetry {
  id         String   @id @default(cuid())
  questionId String   @unique
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  stage      Int      @default(0) // 0 -> 24h, 1 -> 72h, 2 -> 7d
  dueAt      DateTime
  wrongCount Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([dueAt])
}

model GameProfile {
  id               String                  @id @default("default")
  xp               Int                     @default(0)
  level            Int                     @default(1)
  difficultyPreset GameDifficultyPreset    @default(STANDARD)
  coins            Int                     @default(0)
  streakDays       Int                     @default(0)
  lastStreakDate   String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  sessions         GameSessionLog[]
  fsrsProfile      FSRSProfile?
  reviewEvents     ReviewEvent[]
  outputPractices  OutputPractice[]
  studyProgresses  MaterialStudyProgress[]
  playtimeStats    MaterialPlaytimeStat[]
}

model MaterialStudyProgress {
  id              String      @id @default(uuid())
  profileId       String      @default("default") @map("profile_id")
  materialId      String      @map("material_id")
  learningMode    String      @default("default") @map("learning_mode")
  progressPercent Float       @default(0) @map("progress_percent")
  lastPosition    String?     @map("last_position")
  startedAt       DateTime    @default(now()) @map("started_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  profile         GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  material        Material    @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([profileId, materialId, learningMode])
  @@index([updatedAt])
  @@map("material_study_progresses")
}

model MaterialPlaytimeStat {
  id           String      @id @default(uuid())
  profileId    String      @default("default") @map("profile_id")
  materialId   String      @map("material_id")
  totalSeconds Int         @default(0) @map("total_seconds")
  playedDays   Int         @default(0) @map("played_days")
  lastPlayedAt DateTime?   @map("last_played_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  profile      GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  material     Material    @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([profileId, materialId])
  @@index([materialId, updatedAt])
  @@map("material_playtime_stats")
}

enum GameDifficultyPreset {
  CONSERVATIVE
  STANDARD
  AGGRESSIVE
}

model FSRSProfile {
  id                 String      @id @default(cuid())
  profileId          String      @unique
  profile            GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  requestRetention   Float       @default(0.9)
  maximumInterval    Int         @default(36500)
  weights            String
  sampleSize         Int         @default(0)
  fitVersion         Int         @default(1)
  enabled            Boolean     @default(true)
  lastEngineMode     String      @default("custom")
  lastFallbackReason String?
  lastFallbackAt     DateTime?
  lastFittedAt       DateTime?
  lastEventAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model ReviewEvent {
  id               String      @id @default(cuid())
  profileId        String
  profile          GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reviewId         String
  sourceType       SourceType
  sourceId         String
  rating           Int
  deltaDays        Int
  scheduledDays    Int
  stateBefore      Int
  stateAfter       Int
  stabilityBefore  Float
  stabilityAfter   Float
  difficultyBefore Float
  difficultyAfter  Float
  dueAt            DateTime
  reviewedAt       DateTime    @default(now())
  wasOverdue       Boolean
  wasRecallSuccess Boolean

  @@index([profileId, reviewedAt])
  @@index([reviewId, reviewedAt])
}

model GameSessionLog {
  id          String      @id @default(cuid())
  profileId   String
  profile     GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  dateKey     String
  taskKey     String
  taskTitle   String
  points      Int
  coins       Int         @default(0)
  durationMin Int         @default(0)
  completedAt DateTime    @default(now())

  @@unique([profileId, dateKey, taskKey])
  @@index([dateKey])
}

enum StudyTimeKind {
  LESSON_SPEAKING
  ARTICLE_READING
}

model StudyTimeDaily {
  id        String        @id @default(cuid())
  dateKey   String
  kind      StudyTimeKind
  seconds   Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([dateKey, kind])
  @@index([dateKey])
}

model LearningDiary {
  id        String   @id @default(cuid())
  dateKey   String   @unique
  content   String
  wordCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MorningRecall {
  id              String   @id @default(cuid())
  dateKey         String   @unique
  sourceDateKey   String
  prompt          String
  content         String
  wordCount       Int      @default(0)
  aiCoachPrompt   String?
  aiFeedbackRaw   String?
  totalScore      Int      @default(0)
  accuracy        Int      @default(0)
  coverage        Int      @default(0)
  clarity         Int      @default(0)
  feedbackSummary String?
  actionItems     String?
  modelAnswer     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum OutputPracticeType {
  WRITING
}

model OutputPractice {
  id                String             @id @default(cuid())
  profileId         String
  profile           GameProfile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  dateKey           String
  practiceType      OutputPracticeType @default(WRITING)
  languageCode      String             @default("ja")
  missionPrompt     String
  missionText       String
  learnerText       String
  aiCoachPrompt     String
  aiFeedbackRaw     String
  totalScore        Int                @default(0)
  comprehensibility Int                @default(0)
  accuracy          Int                @default(0)
  complexity        Int                @default(0)
  taskCompletion    Int                @default(0)
  feedbackSummary   String?
  actionItems       String?
  wordCount         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([profileId, dateKey, practiceType])
  @@index([dateKey])
}
