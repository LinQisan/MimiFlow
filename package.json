{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "clean:next": "rm -rf .next",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate --config prisma.config.ts",
